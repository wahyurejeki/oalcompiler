controller BookController {
    function indexAction(Request req) {
        return json(["success" => true]);
    }

    function listBooksAction(Request req) {
        var books = Book.modelFindAll();
        return json(books);
    }

    function showBookAction(Request req) {
        var book = Book.modelFindOne(["id" => req.id]);
        if (book) {
            return json(book);
        }
        return json(["error" => "Book not found"]);
    }

    function createBookAction(Request req) {
        var book = Book.modelCreate([
            "title" => req.title,
            "isbn" => req.isbn,
            "year" => req.year,
            "Category_id" => req.Category_id,
            "Publisher_id" => req.Publisher_id,
            "available" => true
        ]);
        return json(["success" => true, "book" => book]);
    }

    function updateBookAction(Request req) {
        var book = Book.modelFindOne(["id" => req.id]);
        if (book) {
            Book.modelUpdate(["id" => req.id], [
                "title" => req.title,
                "isbn" => req.isbn,
                "year" => req.year,
                "Category_id" => req.Category_id,
                "Publisher_id" => req.Publisher_id,
                "available" => req.available
            ]);
            return json(["success" => true]);
        }
        return json(["error" => "Book not found"]);
    }

    function deleteBookAction(Request req) {
        var book = Book.modelFindOne(["id" => req.id]);
        if (book) {
            Book.modelDelete(["id" => req.id]);
            return json(["success" => true]);
        }
        return json(["error" => "Book not found"]);
    }

    function borrowBookAction(Request req) {
        var book = Book.modelFindOne(["id" => req.bookId]);
        if (book.available) {
            var due = req.dueDate;
            var record = BorrowRecord.modelCreate([
                "Book_id" => book.id,
                "Member_id" => req.memberId,
                "borrowedAt" => req.borrowedAt,
                "dueDate" => due
            ]);
            Book.modelUpdate(["id" => book.id], ["available" => false]);
            return json(["success" => true, "borrowId" => record.id]);
        } else {
            return json(["error" => "Book is currently unavailable"]);
        }
    }

    function returnBookAction(Request req) {
        var record = BorrowRecord.modelFindOne(["Book_id" => req.bookId, "returnedAt" => null]);
        if (record) {
            var returnedTime = req.returnedAt;
            BorrowRecord.modelUpdate(["id" => record.id], ["returnedAt" => returnedTime]);
            Book.modelUpdate(["id" => req.bookId], ["available" => true]);

            // If returned after due date, create a fine
            if (returnedTime > record.dueDate) {
                var denda = Fine.modelCreate([
                    "BorrowRecord_id" => record.id,
                    "Member_id" => record.Member_id,
                    "amount" => 50000.00,
                    "isPaid" => false
                ]);
                return json(["success" => true, "status" => "returned_with_fine", "fineAmount" => 50000.00]);
            }
            return json(["success" => true, "status" => "returned_on_time"]);
        } else {
            return json(["error" => "No active borrow record found"]);
        }
    }
}

controller MemberController {
    function listMembersAction(Request req) {
        var members = Member.modelFindAll();
        return json(members);
    }

    function showMemberAction(Request req) {
        var m = Member.modelFindOne(["id" => req.id]);
        if (m) {
            return json(m);
        }
        return json(["error" => "Member not found"]);
    }

    function registerMemberAction(Request req) {
        var m = Member.modelCreate([
            "name" => req.name,
            "email" => req.email,
            "phone" => req.phone,
            "membershipDate" => req.membershipDate,
            "status" => "active"
        ]);
        return json(["success" => true, "memberId" => m.id]);
    }

    function updateMemberAction(Request req) {
        var m = Member.modelFindOne(["id" => req.id]);
        if (m) {
            Member.modelUpdate(["id" => req.id], [
                "name" => req.name,
                "email" => req.email,
                "phone" => req.phone,
                "status" => req.status
            ]);
            return json(["success" => true]);
        }
        return json(["error" => "Member not found"]);
    }

    function deleteMemberAction(Request req) {
        var m = Member.modelFindOne(["id" => req.id]);
        if (m) {
            Member.modelDelete(["id" => req.id]);
            return json(["success" => true]);
        }
        return json(["error" => "Member not found"]);
    }
}

controller ReservationController {
    function listReservationsAction(Request req) {
        var res = Reservation.modelFindAll();
        return json(res);
    }

    function showReservationAction(Request req) {
        var res = Reservation.modelFindOne(["id" => req.id]);
        if (res) {
            return json(res);
        }
        return json(["error" => "Reservation not found"]);
    }

    function reserveBookAction(Request req) {
        var book = Book.modelFindOne(["id" => req.bookId]);
        if (book) {
            var res = Reservation.modelCreate([
                "Book_id" => book.id,
                "Member_id" => req.memberId,
                "reservedAt" => req.reservedAt,
                "status" => "pending"
            ]);
            return json(["success" => true, "reservationId" => res.id]);
        }
        return json(["error" => "Book not found"]);
    }

    function cancelReservationAction(Request req) {
        var res = Reservation.modelFindOne(["id" => req.id]);
        if (res) {
            Reservation.modelDelete(["id" => req.id]);
            return json(["success" => true]);
        }
        return json(["error" => "Reservation not found"]);
    }
}

controller FineController {
    function listFinesAction(Request req) {
        var fines = Fine.modelFindAll();
        return json(fines);
    }

    function showFineAction(Request req) {
        var fine = Fine.modelFindOne(["id" => req.id]);
        if (fine) {
            return json(fine);
        }
        return json(["error" => "Fine record not found"]);
    }

    function payFineAction(Request req) {
        var fine = Fine.modelFindOne(["id" => req.fineId]);
        if (fine) {
            Fine.modelUpdate(["id" => fine.id], ["isPaid" => true]);
            return json(["success" => true]);
        }
        return json(["error" => "Fine record not found"]);
    }
}

// ================= Middlewares =================
middleware AuthMiddleware {
    function handleAction(Request req) {
        if (req.token != "123456") {
            return json(["error" => "Token invalid"]);
        }
    }
}

// ================= Routes =================
route get "/" -> BookController@indexAction;
route get "/books" -> BookController@listBooksAction middleware AuthMiddleware;
route get "/books/detail" -> BookController@showBookAction middleware AuthMiddleware;
route post "/books" -> BookController@createBookAction middleware AuthMiddleware;
route put "/books" -> BookController@updateBookAction middleware AuthMiddleware;
route delete "/books" -> BookController@deleteBookAction middleware AuthMiddleware;
route post "/books/borrow" -> BookController@borrowBookAction middleware AuthMiddleware;
route post "/books/return" -> BookController@returnBookAction middleware AuthMiddleware;

route get "/categories" -> CategoryController@listCategoriesAction;
route get "/categories/detail" -> CategoryController@showCategoryAction;
route post "/categories" -> CategoryController@createCategoryAction;
route put "/categories" -> CategoryController@updateCategoryAction;
route delete "/categories" -> CategoryController@deleteCategoryAction;

route get "/publishers" -> PublisherController@listPublishersAction;
route get "/publishers/detail" -> PublisherController@showPublisherAction;
route post "/publishers" -> PublisherController@createPublisherAction;
route put "/publishers" -> PublisherController@updatePublisherAction;
route delete "/publishers" -> PublisherController@deletePublisherAction;

route get "/authors" -> AuthorController@listAuthorsAction;
route get "/authors/detail" -> AuthorController@showAuthorAction;
route post "/authors" -> AuthorController@createAuthorAction;
route put "/authors" -> AuthorController@updateAuthorAction;
route delete "/authors" -> AuthorController@deleteAuthorAction;

route get "/members" -> MemberController@listMembersAction;
route get "/members/detail" -> MemberController@showMemberAction;
route post "/members" -> MemberController@registerMemberAction;
route put "/members" -> MemberController@updateMemberAction;
route delete "/members" -> MemberController@deleteMemberAction;

route get "/reservations" -> ReservationController@listReservationsAction middleware AuthMiddleware;
route get "/reservations/detail" -> ReservationController@showReservationAction middleware AuthMiddleware;
route post "/reservations" -> ReservationController@reserveBookAction middleware AuthMiddleware;
route delete "/reservations" -> ReservationController@cancelReservationAction middleware AuthMiddleware;

route get "/fines" -> FineController@listFinesAction middleware AuthMiddleware;
route get "/fines/detail" -> FineController@showFineAction middleware AuthMiddleware;
route post "/fines/pay" -> FineController@payFineAction middleware AuthMiddleware;